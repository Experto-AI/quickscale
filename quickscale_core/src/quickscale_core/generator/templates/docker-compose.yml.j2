services:
  db:
    image: postgres:17-alpine
    container_name: {{ project_name }}_db
    environment:
      POSTGRES_DB: {{ package_name }}
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    volumes:
      - postgres_data:/var/lib/postgresql/data
    # Port mapping removed to avoid conflicts with system PostgreSQL
    # The backend service can still access the database via the internal Docker network
    # If you need to access PostgreSQL from your host, uncomment the next 2 lines:
    # ports:
    #   - "5433:5432"  # Maps to host port 5433 to avoid conflict with system PostgreSQL
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

{% if theme == 'showcase_react' %}
  frontend:
    image: node:20-slim
    container_name: {{ project_name }}_frontend
    # Map to host user to prevent root-owned files in mounted volumes
    user: "${DOCKER_UID:-1000}:${DOCKER_GID:-1000}"
    working_dir: /app/frontend
    environment:
      - HOME=/tmp
    # Use corepack without `enable` because this container runs as non-root.
    # `corepack enable` writes to /usr/local/bin and fails with EACCES.
    command: sh -c "corepack pnpm install --no-frozen-lockfile && corepack pnpm run build"
    volumes:
      - .:/app
{% endif %}

  backend:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        INSTALL_DEV: "true"  # Install dev dependencies for local development
    container_name: {{ project_name }}_backend
    command: python manage.py runserver 0.0.0.0:${PORT:-8000}
    # Map to host user to prevent root-owned files in mounted volumes
    user: "${DOCKER_UID:-1000}:${DOCKER_GID:-1000}"
    volumes:
      - .:/app
      - static_volume:/app/staticfiles
      - media_volume:/app/media
    ports:
      - "${PORT:-8000}:${PORT:-8000}"
    environment:
      - DJANGO_SETTINGS_MODULE={{ package_name }}.settings.local
      - DATABASE_URL=postgresql://postgres:postgres@db:5432/{{ package_name }}
      - PORT=${PORT:-8000}
    depends_on:
      db:
        condition: service_healthy
{% if theme == 'showcase_react' %}
      frontend:
        condition: service_completed_successfully
{% endif %}

volumes:
  postgres_data:
  static_volume:
  media_volume:
