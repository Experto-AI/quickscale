# Docker User Mapping
# Prevents Docker containers from creating root-owned files in mounted volumes
# Auto-generated from host user (UID={{ host_uid }}, GID={{ host_gid }})
DOCKER_UID={{ host_uid }}
DOCKER_GID={{ host_gid }}

# Server Configuration
PORT=8000

# Local PostgreSQL (required for local settings)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/{{ package_name }}
