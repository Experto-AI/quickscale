{%raw%}{% extends "base.html" %}

{% block title %}Social | {% endraw %}{{ project_name }}{% raw %}{% endblock %}

{% block content %}{% endraw %}
<div class="qs-social-shell">
    <aside class="qs-social-rail">
        <span class="qs-social-rail-eyebrow">Public Social Surface</span>
        <h1>Social</h1>
        <p class="qs-social-rail-copy">
            This page stays public and shareable outside the HTML showcase dashboard while still following the same visual language.
        </p>

        <section class="qs-social-rail-group">
            <span class="qs-social-rail-label">Navigate</span>
            <nav class="qs-social-nav" aria-label="Social page navigation">
                <a class="qs-social-nav-link qs-social-nav-link-active" href="/social">Link tree</a>
                {%raw%}{% if settings.QUICKSCALE_SOCIAL_EMBEDS_ENABLED %}{%endraw%}
                <a class="qs-social-nav-link" href="/social/embeds">Embeds</a>
                {%raw%}{% endif %}{%endraw%}
                <a class="qs-social-nav-link" href="/">App home</a>
            </nav>
        </section>

        <section class="qs-social-rail-group">
            <span class="qs-social-rail-label">Current setup</span>
            <dl class="qs-social-meta">
                <div>
                    <dt>Status</dt>
                    <dd>{%raw%}{% if settings.QUICKSCALE_SOCIAL_LINK_TREE_ENABLED %}Enabled{% else %}Disabled{% endif %}{%endraw%}</dd>
                </div>
                <div>
                    <dt>Layout</dt>
                    <dd><code>{%raw%}{{ settings.QUICKSCALE_SOCIAL_LAYOUT_VARIANT }}{%endraw%}</code></dd>
                </div>
                <div>
                    <dt>Links / page</dt>
                    <dd><code>{%raw%}{{ settings.QUICKSCALE_SOCIAL_LINKS_PER_PAGE }}{%endraw%}</code></dd>
                </div>
            </dl>
        </section>
    </aside>

    <div class="qs-social-stack">
        <section class="qs-social-hero">
            <span class="qs-social-pill">
                {%raw%}{% if settings.QUICKSCALE_SOCIAL_LINK_TREE_ENABLED %}Link tree enabled{% else %}Link tree disabled{% endif %}{%endraw%}
            </span>
            <h1>Social Link Tree</h1>
            <p class="qs-social-copy">
                QuickScale reserves <code>/social</code> as the public social surface for curated links.
                This page gives the route a stable home even before any social links have been published.
            </p>
            <div class="hero-actions">
                {%raw%}{% if settings.QUICKSCALE_SOCIAL_EMBEDS_ENABLED %}{%endraw%}
                <a class="btn btn-primary btn-inline" href="/social/embeds">Browse embeds</a>
                {%raw%}{% endif %}{%endraw%}
                <a class="btn btn-secondary btn-inline" href="/">Return home</a>
            </div>
        </section>

        <section class="qs-social-grid">
            <article class="qs-social-card">
                <h2>Status</h2>
                {%raw%}{% if settings.QUICKSCALE_SOCIAL_LINK_TREE_ENABLED %}{%endraw%}
                <p>The public link tree surface is enabled at <code>/social</code>.</p>
                {%raw%}{% else %}{%endraw%}
                <p>The public link tree surface is currently disabled in project settings.</p>
                {%raw%}{% endif %}{%endraw%}
            </article>

            <article class="qs-social-card">
                <h2>Layout</h2>
                <p>Configured layout variant: <code>{%raw%}{{ settings.QUICKSCALE_SOCIAL_LAYOUT_VARIANT }}{%endraw%}</code></p>
                <p>Links per page: <code>{%raw%}{{ settings.QUICKSCALE_SOCIAL_LINKS_PER_PAGE }}{%endraw%}</code></p>
            </article>

            <article class="qs-social-card">
                <h2>Providers</h2>
                <ul class="qs-social-list">
                    {%raw%}{% for provider in settings.QUICKSCALE_SOCIAL_PROVIDER_ALLOWLIST %}{%endraw%}
                    <li>{%raw%}{{ provider }}{%endraw%}</li>
                    {%raw%}{% endfor %}{%endraw%}
                </ul>
            </article>

            <article class="qs-social-card qs-social-empty">
                <h2>Published Links</h2>
                <p>No curated social links are available yet.</p>
                <p>This generated page keeps the public route stable instead of dropping visitors into a generic showcase screen.</p>
            </article>
        </section>
    </div>
</div>
{%raw%}{% endblock %}{%endraw%}
