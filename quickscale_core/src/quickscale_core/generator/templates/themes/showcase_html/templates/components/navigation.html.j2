{%raw%}<nav class="site-nav">
    <div class="nav-container">
        <div class="nav-header">
            <a href="/" class="nav-brand">{% endraw %}{{ project_name }}{%raw%}</a>
            <p class="nav-tagline">Showcase HTML starter</p>
        </div>

        <ul class="nav-menu">
            <li class="nav-home"><a href="/">Dashboard</a></li>

            {% if 'quickscale_modules_auth' in settings.INSTALLED_APPS %}
            <li class="nav-section">
                <span class="nav-section-title">Authentication</span>
                <ul class="nav-submenu">
                    {% if user.is_authenticated %}
                    <li><a href="{% url 'quickscale_auth:profile' %}">Profile</a></li>
                    <li><a href="{% url 'quickscale_auth:profile-edit' %}">Edit Profile</a></li>
                    <li><a href="{% url 'account_change_password' %}">Change Password</a></li>
                    <li><a href="{% url 'account_logout' %}">Logout</a></li>
                    {% else %}
                    <li><a href="{% url 'account_login' %}">Login</a></li>
                    <li><a href="{% url 'account_signup' %}">Sign Up</a></li>
                    <li><a href="{% url 'account_reset_password' %}">Reset Password</a></li>
                    {% endif %}
                </ul>
            </li>
            {% endif %}

            {% if 'quickscale_modules_blog' in settings.INSTALLED_APPS %}
            <li class="nav-section">
                <span class="nav-section-title">Blog</span>
                <ul class="nav-submenu">
                    <li><a href="{% url 'quickscale_blog:post_list' %}">All Posts</a></li>
                    <li><a href="{% url 'quickscale_blog:feed' %}">RSS Feed</a></li>
                </ul>
            </li>
            {% endif %}

            {% if 'quickscale_modules_listings' in settings.INSTALLED_APPS %}
            <li class="nav-section">
                <span class="nav-section-title">Listings</span>
                <ul class="nav-submenu">
                    <li><a href="{% url 'quickscale_listings:listing_list' %}">All Listings</a></li>
                </ul>
            </li>
            {% endif %}

            {% if 'quickscale_modules_crm' in settings.INSTALLED_APPS %}
            <li class="nav-section">
                <span class="nav-section-title">CRM</span>
                <ul class="nav-submenu">
                    <li><a href="{% url 'quickscale_crm:dashboard' %}">Dashboard</a></li>
                </ul>
            </li>
            {% endif %}

            {% if 'quickscale_modules_forms' in settings.INSTALLED_APPS %}
            <li class="nav-section">
                <span class="nav-section-title">Forms</span>
                <ul class="nav-submenu">
                    <li><a href="/admin/">Manage forms in Django Admin</a></li>
                    <li><span class="nav-disabled-link">Open public forms at /forms/&lt;slug&gt;/ after creating them.</span></li>
                </ul>
            </li>
            {% endif %}

            {% if 'quickscale_modules_billing' in settings.INSTALLED_APPS %}
            <li class="nav-section">
                <span class="nav-section-title">Billing</span>
                <ul class="nav-submenu">
                    <li><span class="nav-disabled-link">Add project-specific billing views to surface this module.</span></li>
                </ul>
            </li>
            {% endif %}

            {% if 'quickscale_modules_teams' in settings.INSTALLED_APPS %}
            <li class="nav-section">
                <span class="nav-section-title">Teams</span>
                <ul class="nav-submenu">
                    <li><span class="nav-disabled-link">Add team views when your collaboration flows are ready.</span></li>
                </ul>
            </li>
            {% endif %}

            {% if 'quickscale_modules_storage' in settings.INSTALLED_APPS %}
            <li class="nav-section">
                <span class="nav-section-title">Storage</span>
                <ul class="nav-submenu">
                    <li><span class="nav-disabled-link">Shared media storage infrastructure with no public page.</span></li>
                </ul>
            </li>
            {% endif %}

            <li class="nav-section">
                <span class="nav-section-title">Resources</span>
                <ul class="nav-submenu">
                    <li><a href="/admin/">Django Admin</a></li>
                    <li><a href="https://github.com/Experto-AI/quickscale" target="_blank" rel="noopener noreferrer">QuickScale Docs</a></li>
                </ul>
            </li>
        </ul>
    </div>
</nav>{%endraw%}
