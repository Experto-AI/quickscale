{% raw -%}
interface QuickScaleModules {
  auth: boolean
  blog: boolean
  listings: boolean
  crm: boolean
  forms: boolean
  storage: boolean
  backups: boolean
  notifications: boolean
  social: boolean
  billing: boolean
  teams: boolean
}

interface QuickScaleModulePaths {
  social: string
}

interface QuickScaleConfig {
  projectName: string
  modules: QuickScaleModules
  modulePaths: QuickScaleModulePaths
}

declare global {
  interface Window {
    __QUICKSCALE__?: QuickScaleConfig
  }
}

const defaultConfig: QuickScaleConfig = {
  projectName: '{% endraw %}{{ project_name }}{% raw %}',
  modules: {
    auth: false,
    blog: false,
    listings: false,
    crm: false,
    forms: false,
    storage: false,
    backups: false,
    notifications: false,
    social: false,
    billing: false,
    teams: false,
  },
  modulePaths: {
    social: '/social',
  },
}

export function useModules(): QuickScaleModules {
  return (window.__QUICKSCALE__ ?? defaultConfig).modules
}

export function useProjectConfig(): QuickScaleConfig {
  return window.__QUICKSCALE__ ?? defaultConfig
}
{% endraw -%}
