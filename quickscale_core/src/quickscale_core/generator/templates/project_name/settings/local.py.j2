"""
Local development settings for {{ project_name }}.

This file contains settings specific to local development:
- DEBUG mode enabled
- PostgreSQL database via DATABASE_URL (required)
- Django Debug Toolbar (optional)
- Relaxed security settings

DO NOT use these settings in production!
"""

from typing import Any

import dj_database_url
from decouple import config

from .base import *  # noqa: F403

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG = True

# Allow all hosts in development (including Docker containers running on 0.0.0.0)
ALLOWED_HOSTS = ["localhost", "127.0.0.1", "[::1]", "0.0.0.0", "*"]

# Database - PostgreSQL required for local development
database_url = config("DATABASE_URL", default=None)
if not database_url:
    raise ValueError(
        "DATABASE_URL is required in local settings. "
        "Set DATABASE_URL in your .env file before running manage.py commands."
    )

DATABASES: dict[str, Any] = {  # type: ignore[no-redef]  # noqa: F405
    "default": dj_database_url.parse(
        database_url,
        conn_max_age=0,
        ssl_require=False,
    )
}

# Django Debug Toolbar (uncomment to enable)
# INSTALLED_APPS += ["debug_toolbar"]  # noqa: F405
# MIDDLEWARE += ["debug_toolbar.middleware.DebugToolbarMiddleware"]  # noqa: F405
# INTERNAL_IPS = ["127.0.0.1"]

# Email backend - console output for development unless managed module wiring
# already took ownership (for example, live notifications delivery).
if "EMAIL_BACKEND" not in globals():
    EMAIL_BACKEND = "django.core.mail.backends.console.EmailBackend"

# Disable password validation in development (optional, for convenience)
# AUTH_PASSWORD_VALIDATORS = []  # noqa: F405

# Simplified static file serving in development while preserving the selected
# default media storage backend from base settings/module wiring.
STORAGES["staticfiles"] = {
    "BACKEND": "django.contrib.staticfiles.storage.StaticFilesStorage",
}

# CORS settings (if using Django CORS Headers)
# CORS_ALLOW_ALL_ORIGINS = True  # Only for development!

# Logging - more verbose in development
LOGGING = {
    "version": 1,
    "disable_existing_loggers": False,
    "formatters": {
        "verbose": {
            "format": "{levelname} {asctime} {module} {message}",
            "style": "{",
        },
    },
    "handlers": {
        "console": {
            "class": "logging.StreamHandler",
            "formatter": "verbose",
        },
    },
    "root": {
        "handlers": ["console"],
        "level": "DEBUG",
    },
    "loggers": {
        "django": {
            "handlers": ["console"],
            "level": "INFO",
            "propagate": False,
        },
        "{{ package_name }}": {
            "handlers": ["console"],
            "level": "DEBUG",
            "propagate": False,
        },
    },
}
