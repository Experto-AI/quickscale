{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quickscale.dev/schemas/agentic-flow.schema.json",
  "title": "Agentic Flow IR",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "config",
    "agents",
    "subagents",
    "skills",
    "workflows",
    "contexts",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "required": ["output_directory", "lint_command", "test_command", "platforms"],
      "properties": {
        "output_directory": {"type": "string"},
        "lint_command": {"type": "string"},
        "test_command": {"type": "string"},
        "strict_mode": {"type": "boolean"},
        "platforms": {
          "type": "object",
          "required": [
            "claude_code",
            "gemini_cli",
            "gemini_antigravity",
            "github_copilot",
            "copilot_cli",
            "codex_cli",
            "opencode"
          ],
          "properties": {
            "claude_code": {"$ref": "#/$defs/platform_config"},
            "gemini_cli": {"$ref": "#/$defs/platform_config"},
            "gemini_antigravity": {"$ref": "#/$defs/platform_config"},
            "github_copilot": {"$ref": "#/$defs/platform_config"},
            "copilot_cli": {"$ref": "#/$defs/platform_config"},
            "codex_cli": {"$ref": "#/$defs/platform_config"},
            "opencode": {"$ref": "#/$defs/platform_config"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "agents": {
      "type": "array",
      "items": {"$ref": "#/$defs/entity"}
    },
    "subagents": {
      "type": "array",
      "items": {"$ref": "#/$defs/entity"}
    },
    "skills": {
      "type": "array",
      "items": {"$ref": "#/$defs/entity"}
    },
    "workflows": {
      "type": "array",
      "items": {"$ref": "#/$defs/entity"}
    },
    "contexts": {
      "type": "array",
      "items": {"$ref": "#/$defs/entity"}
    },
    "diagnostics": {
      "type": "object",
      "required": ["errors", "warnings"],
      "properties": {
        "errors": {
          "type": "array",
          "items": {"type": "string"}
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "platform_config": {
      "type": "object",
      "required": ["enabled", "support_mode", "experimental"],
      "properties": {
        "enabled": {"type": "boolean"},
        "support_mode": {
          "type": "string",
          "enum": ["native", "emulated", "disabled"]
        },
        "experimental": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "entity": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "path",
        "directives",
        "contract"
      ],
      "properties": {
        "name": {"type": "string"},
        "kind": {"type": "string"},
        "path": {"type": "string"},
        "description": {"type": "string"},
        "mode": {"type": ["string", "null"]},
        "skills": {
          "type": "array",
          "items": {"type": "string"}
        },
        "delegates_to": {
          "type": "array",
          "items": {"type": "string"}
        },
        "workflows": {
          "type": "array",
          "items": {"type": "string"}
        },
        "requires": {
          "type": "array",
          "items": {"type": "string"}
        },
        "provides": {
          "type": "array",
          "items": {"type": "string"}
        },
        "directives": {
          "type": "object",
          "properties": {
            "skills": {
              "type": "array",
              "items": {"type": "string"}
            },
            "agents": {
              "type": "array",
              "items": {"type": "string"}
            },
            "workflows": {
              "type": "array",
              "items": {"type": "string"}
            }
          },
          "additionalProperties": false
        },
        "contract": {
          "type": "object",
          "properties": {
            "inputs_yaml": {"type": "string"},
            "outputs_yaml": {"type": "string"},
            "success_when_yaml": {"type": "string"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
